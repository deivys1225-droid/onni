# Opcional: el cliente puede usar valores por defecto embebidos.
#
# Supabase → Settings → API:
#   Project URL → VITE_SUPABASE_URL
#   anon / publishable → VITE_SUPABASE_PUBLISHABLE_KEY
# NUNCA pongas service_role aquí.
#
# Supabase → Authentication → URL Configuration: Site URL y Redirect URLs deben incluir este dominio (sin barra final).
# Ej.: Site URL https://onnivers.com y Redirect URLs https://onnivers.com/entrar , https://onnivers.com/actualizar-contrasena

VITE_SITE_URL=https://onnivers.com
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_AGORA_APP_ID=

# Mux — producción en Vercel (Settings → Environment Variables):
#   MUX_TOKEN_ID, MUX_TOKEN_SECRET  (servidor; no exponer en el cliente)
# VITE_MUX_API_URL vacío en producción → el front llama a /api/mux/create-stream del mismo dominio.
# Local con mux-api: VITE_MUX_API_URL=http://localhost:8787 (Vite proxy /api/mux → :8787, incl. WebSocket)
# Emisión desde navegador requiere mux-api con ffmpeg: cd mux-api && npm run dev
# VITE_MUX_WS_URL=ws://localhost:8787

# PayPal Developer → Apps & Credentials → REST app → Client ID (público en el navegador).
# En local: VITE_PAYPAL_ENVIRONMENT=sandbox (sin Client ID, dev usa client-id=test para cargar el SDK).
VITE_PAYPAL_CLIENT_ID=
VITE_PAYPAL_ENVIRONMENT=sandbox

# También válido:
# VITE_SUPABASE_ANON_KEY=

# Conciertos Live — en npm run dev el flujo premium está activo para pruebas.
# Pon false para simular usuario sin pago en local.
# VITE_CONCIERTO_LIVE_DEV_ACCESS=false

# Onni + IA local (Ollama — principal en dev) + OpenRouter (respaldo / Telegram en Vercel):
# Local (.env.local gitignored):
#   OLLAMA_ENABLED=true
#   OLLAMA_MODEL=gemma3:1b
#   OLLAMA_HOST=http://127.0.0.1:11434
#   OLLAMA_ONLY=true          (opcional; si Ollama falla y hay clave, usa OpenRouter)
#   OPENROUTER_API_KEY=sk-or-v1-...   (respaldo y bot Telegram en Vercel)
#   OPENROUTER_MODEL=openrouter/free
# Producción Vercel → Settings → Environment Variables:
#   OPENROUTER_API_KEY=sk-or-v1-...
#   OPENROUTER_MODEL=openrouter/free
#   OPENROUTER_SITE_URL=https://onnivers.com   (opcional, recomendado por OpenRouter)
# Producción Supabase → Edge Functions → Secrets (onni-gemini):
#   OPENROUTER_API_KEY, opcional OPENROUTER_MODEL
# Modelos free alternativos OpenRouter: meta-llama/llama-3.2-3b-instruct:free, etc.
#
# Onni en Telegram (@Onniasistente_bot):
#   TELEGRAM_BOT_TOKEN=...          (BotFather; NUNCA en el repo)
#   TELEGRAM_WEBHOOK_SECRET=...     (opcional; mismo valor al registrar webhook)
#   TELEGRAM_ALLOWED_CHAT_IDS=      (opcional; solo esos chat_id mientras pruebas)
# Tras deploy en Vercel:
#   node scripts/telegram-set-webhook.mjs
#   (TELEGRAM_WEBHOOK_URL=https://onnivers.com/api/telegram-webhook)
